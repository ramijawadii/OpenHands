# Run frontend checks
echo "Running frontend checks..."
cd frontend
npx lint-staged

# Run backend pre-commit (skip if poetry not available, e.g. on Windows)
echo "Running backend pre-commit..."
cd ..
if command -v poetry &> /dev/null; then
  poetry run pre-commit run --files openhands/**/* evaluation/**/* tests/**/* --show-diff-on-failure --config ./dev_config/python/.pre-commit-config.yaml
else
  echo "poetry not found in PATH, skipping backend pre-commit (run manually in Docker)"
fi
